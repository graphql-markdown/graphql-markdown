{
  "name": "graphql-markdown",
  "homepage": "https://graphql-markdown.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/graphql-markdown/graphql-markdown.git"
  },
  "packageManager": "bun@1.3.2",
  "private": true,
  "version": "1.0.0",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "graphql": "16.13.2",
      "graphql-config": "5.1.6",
      "prettier": "3.8.1"
    },
    "catalogs": {
      "graphql-tools": {
        "@graphql-tools/load": "8.1.8",
        "@graphql-tools/graphql-file-loader": "8.0.22",
        "@graphql-tools/utils": "11.0.0"
      },
      "docusaurus": {
        "@docusaurus/utils": ">=3.9.2",
        "@docusaurus/types": "^3.7.0",
        "@docusaurus/logger": "*"
      }
    }
  },
  "author": {
    "name": "Gregory Heitz"
  },
  "contributors": [
    {
      "name": "jocrau"
    },
    {
      "name": "mimo84"
    },
    {
      "name": "coder2034"
    },
    {
      "name": "lauzierj"
    },
    {
      "name": "jineshshah36"
    },
    {
      "name": "GuiHash"
    },
    {
      "name": "davidyaha"
    },
    {
      "name": "jlndk"
    },
    {
      "name": "elias-pap"
    },
    {
      "name": "melvey"
    },
    {
      "name": "carolstran"
    },
    {
      "name": "chmanie"
    },
    {
      "name": "ljiang-ti"
    }
  ],
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "docs": "turbo run docs",
    "docs:api": "turbo run docs:api:root",
    "docs:api:root": "node ./packages/tooling-config/scripts/docs-api.mjs",
    "knip": "knip --strict",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "prepare": "node ./packages/tooling-config/husky/prepare-husky.js",
    "prettier": "turbo run prettier",
    "prettier:fix": "turbo run prettier:fix",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:ci": "turbo run test:ci",
    "ts:check": "turbo run ts:check",
    "stryker": "turbo stryker"
  },
  "prettier": "./packages/tooling-config/prettier/index.mjs",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-emoji"
    },
    "cz-emoji": {
      "skipQuestions": [
        "scope",
        "issues",
        "breaking"
      ],
      "types": [
        {
          "emoji": "✨",
          "code": ":sparkles:",
          "description": "Add a new feature.",
          "name": "feat"
        },
        {
          "emoji": "🐛",
          "code": ":bug:",
          "description": "Fix a bug.",
          "name": "fix"
        },
        {
          "emoji": "📦️",
          "code": ":package:",
          "description": "Update dependencies.",
          "name": "build"
        },
        {
          "emoji": "🔧",
          "code": ":wrench:",
          "description": "Update configuration files.",
          "name": "conf"
        },
        {
          "emoji": "♻️",
          "code": ":recycle:",
          "description": "Refactor code.",
          "name": "refactor"
        },
        {
          "emoji": "🧪",
          "code": ":test_tube:",
          "description": "Update tests.",
          "name": "test"
        },
        {
          "emoji": "👷",
          "code": ":construction_worker:",
          "description": "Update CI.",
          "name": "ci"
        },
        {
          "emoji": "📝",
          "code": ":memo:",
          "description": "Update documentation.",
          "name": "docs"
        },
        {
          "emoji": "🔖",
          "code": ":bookmark:",
          "description": "Add a tag / release.",
          "name": "tag"
        },
        {
          "emoji": "🧑‍💻",
          "code": ":technologist:",
          "description": "Other changes.",
          "name": "other"
        }
      ]
    }
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@graphql-tools/graphql-file-loader": "8.1.14",
    "@graphql-tools/json-file-loader": "8.0.28",
    "@stryker-mutator/api": "9.6.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/jest-runner": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@typescript/native-preview": "7.0.0-dev.20260426.1",
    "commitizen": "4.3.1",
    "cz-emoji": "1.3.1",
    "diff": "9.0.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jsonc": "3.1.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-tsdoc": "0.5.2",
    "globals": "17.5.0",
    "graphql": "catalog:",
    "graphql-config": "catalog:",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-environment-node": "30.3.0",
    "jsonc-eslint-parser": "3.1.0",
    "knip": "6.7.0",
    "lodash.filter": "4.6.0",
    "memfs": "4.57.2",
    "prettier": "catalog:",
    "ts-jest": "29.4.9",
    "turbo": "2.9.6",
    "typedoc": "0.28.19",
    "typedoc-docusaurus-theme": "1.4.2",
    "typedoc-plugin-frontmatter": "1.3.1",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "unionfs": "4.6.0"
  },
  "overrides": {
    "lodash": "4.18.1"
  }
}
