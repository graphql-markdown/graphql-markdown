{
  "name": "@graphql-markdown/formatters",
  "homepage": "https://graphql-markdown.dev",
  "description": "Formatter presets for Docusaurus, Starlight, Fumadocs, Vocs, HonKit, Hugo, MkDocs, DocFX, and mdBook.",
  "bugs": {
    "url": "https://github.com/graphql-markdown/graphql-markdown/issues"
  },
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphql-markdown/graphql-markdown.git",
    "directory": "packages/formatters"
  },
  "keywords": [
    "graphql",
    "graphql-markdown",
    "docusaurus",
    "starlight",
    "fumadocs",
    "vocs",
    "honkit",
    "hugo",
    "mkdocs",
    "docfx",
    "mdbook",
    "documentation",
    "formatter"
  ],
  "author": {
    "name": "Gregory Heitz"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "default": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    },
    "./docusaurus": {
      "require": { "types": "./dist/docusaurus/index.d.ts", "default": "./dist/docusaurus/index.js" },
      "import": { "types": "./dist/docusaurus/index.d.ts", "default": "./dist/docusaurus/index.js" },
      "default": { "types": "./dist/docusaurus/index.d.ts", "default": "./dist/docusaurus/index.js" }
    },
    "./docfx": {
      "require": { "types": "./dist/docfx/index.d.ts", "default": "./dist/docfx/index.js" },
      "import": { "types": "./dist/docfx/index.d.ts", "default": "./dist/docfx/index.js" },
      "default": { "types": "./dist/docfx/index.d.ts", "default": "./dist/docfx/index.js" }
    },
    "./fumadocs": {
      "require": { "types": "./dist/fumadocs/index.d.ts", "default": "./dist/fumadocs/index.js" },
      "import": { "types": "./dist/fumadocs/index.d.ts", "default": "./dist/fumadocs/index.js" },
      "default": { "types": "./dist/fumadocs/index.d.ts", "default": "./dist/fumadocs/index.js" }
    },
    "./honkit": {
      "require": { "types": "./dist/honkit/index.d.ts", "default": "./dist/honkit/index.js" },
      "import": { "types": "./dist/honkit/index.d.ts", "default": "./dist/honkit/index.js" },
      "default": { "types": "./dist/honkit/index.d.ts", "default": "./dist/honkit/index.js" }
    },
    "./hugo": {
      "require": { "types": "./dist/hugo/index.d.ts", "default": "./dist/hugo/index.js" },
      "import": { "types": "./dist/hugo/index.d.ts", "default": "./dist/hugo/index.js" },
      "default": { "types": "./dist/hugo/index.d.ts", "default": "./dist/hugo/index.js" }
    },
    "./mdbook": {
      "require": { "types": "./dist/mdbook/index.d.ts", "default": "./dist/mdbook/index.js" },
      "import": { "types": "./dist/mdbook/index.d.ts", "default": "./dist/mdbook/index.js" },
      "default": { "types": "./dist/mdbook/index.d.ts", "default": "./dist/mdbook/index.js" }
    },
    "./mkdocs": {
      "require": { "types": "./dist/mkdocs/index.d.ts", "default": "./dist/mkdocs/index.js" },
      "import": { "types": "./dist/mkdocs/index.d.ts", "default": "./dist/mkdocs/index.js" },
      "default": { "types": "./dist/mkdocs/index.d.ts", "default": "./dist/mkdocs/index.js" }
    },
    "./starlight": {
      "require": { "types": "./dist/starlight/index.d.ts", "default": "./dist/starlight/index.js" },
      "import": { "types": "./dist/starlight/index.d.ts", "default": "./dist/starlight/index.js" },
      "default": { "types": "./dist/starlight/index.d.ts", "default": "./dist/starlight/index.js" }
    },
    "./vocs": {
      "require": { "types": "./dist/vocs/index.d.ts", "default": "./dist/vocs/index.js" },
      "import": { "types": "./dist/vocs/index.d.ts", "default": "./dist/vocs/index.js" },
      "default": { "types": "./dist/vocs/index.d.ts", "default": "./dist/vocs/index.js" }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "tsgo --build --clean && rm -rf ./dist",
    "build": "tsgo --build",
    "docs": "typedoc --options typedoc.config.mjs",
    "lint": "eslint --config ../../packages/tooling-config/eslint/config.ts \"{src,tests}/**/*.{ts,js,json,gql}\"",
    "lint:fix": "eslint --config ../../packages/tooling-config/eslint/config.ts \"{src,tests}/**/*.{ts,js,json,gql}\" --fix",
    "prettier": "prettier \"{src,tests}/**/*.{ts,js,json,md,gql}\" --check",
    "prettier:fix": "prettier \"{src,tests}/**/*.{ts,js,json,md,gql}\" --write",
    "ts:check": "tsgo --noEmit",
    "test": "jest",
    "test:unit": "jest --passWithNoTests --testPathPatterns=tests\\/unit",
    "test:integration": "jest --passWithNoTests --testPathPatterns=tests\/integration",
    "test:ci": "jest --passWithNoTests --ci --silent --randomize --runInBand"
  },
  "dependencies": {
    "@graphql-markdown/helpers": "workspace:^",
    "@graphql-markdown/types": "workspace:^",
    "@graphql-markdown/utils": "workspace:^"
  },
  "devDependencies": {
    "@graphql-markdown/tooling-config": "workspace:^"
  },
  "directories": {
    "test": "tests"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "typescript": {
    "definition": "dist/index.d.ts"
  },
  "files": [
    "dist"
  ]
}
