{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "composite": true,

    "rootDir": "src",
    "outDir": "dist",

    "paths": {
      "@graphql-markdown/types": ["../types/src/index.d.ts"],
      "@graphql-markdown/formatters/docusaurus": ["../formatters/src/docusaurus/index.ts"],
      "@graphql-markdown/*": ["../*/dist/index.d.ts"]
    }
  },

  "references": [
    { "path": "../cli" },
    { "path": "../formatters" },
    { "path": "../logger" },
    { "path": "../utils" }
  ]
}
