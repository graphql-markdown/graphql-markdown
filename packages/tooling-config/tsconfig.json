{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "./tsconfig/base.json",

  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": ["eslint/**/*.ts"]
}
