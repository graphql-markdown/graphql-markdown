{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "semanticCommits": "enabled",
  "baseBranchPatterns": [
    "main"
  ],
  "minimumReleaseAge": "2 days",
  "internalChecksFilter": "strict",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Bun workspaces catalog and catalogs dependency versions",
      "managerFilePatterns": [
        "/^package\\.json$/"
      ],
      "matchStrings": [
        "^\\s{6,}\"(?<depName>@?[\\w./-]+)\"\\s*:\\s*\"(?<currentValue>(?:\\^|~|>=)?\\d[^\"]*)\""
      ],
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "/^@graphql-markdown/"
      ]
    },
    {
      "matchFileNames": [
        "website/**"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "matchBaseBranches": [
        "main"
      ],
      "enabled": false
    }
  ]
}
