{
  "workspaces": {
    ".": {
      "entry": ["dangerfile.js", "config/*.js"],
      "project": ["config/**/*.js"],
      "eslint": {
        "config": ["packages/tooling-config/eslint/config.ts"]
      }
    },
    "packages/*": {
      "entry": ["jest.config.mjs"],
      "project": ["**/*.ts!"]
    },
    "packages/core": {
      "entry": ["jest.config.mjs"],
      "ignoreDependencies": ["graphql-config"]
    },
    "packages/utils": {
      "entry": ["jest.config.mjs"],
      "project": ["**/*.ts!"],
      "ignoreDependencies": ["prettier"]
    },
    "packages/tooling-config": {
      "entry": [
        "eslint/config.ts",
        "jest/base.mjs",
        "jest/root.mjs",
        "jest/unit.mjs",
        "jest/integration.mjs",
        "prettier/index.mjs",
        "scripts/build-packages.mjs",
        "scripts/shared/dependencies-utils.mjs",
        "scripts/publish-package.sh",
        "scripts/publish-release.sh",
        "scripts/docs-api.mjs",
        "husky/prepare-husky.js",
        "stryker/stryker.conf.mjs",
        "typedoc/api.mjs",
        "typedoc/base.mjs",
        "typedoc/root.mjs",
        "typedoc/custom-frontmatter.mjs",
        "typedoc/no-media-plugin.mjs"
      ],
      "ignoreDependencies": [
        "@eslint/js",
        "@graphql-eslint/eslint-plugin",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser",
        "eslint-config-prettier",
        "eslint-plugin-import",
        "eslint-plugin-jest",
        "eslint-plugin-jsonc",
        "eslint-plugin-mdx",
        "eslint-plugin-prettier",
        "eslint-plugin-tsdoc",
        "globals",
        "jsonc-eslint-parser"
      ]
    }
  },
  "ignoreDependencies": [
    "@docusaurus/logger",
    "commitizen",
    "danger",
    "husky",
    "jest-environment-node"
  ],
  "jest": {
    "config": ["packages/*/jest.config.mjs"],
    "entry": ["**/tests/**/*.ts"]
  }
}
