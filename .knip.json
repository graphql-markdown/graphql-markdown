{
  "workspaces": {
    ".": {
      "entry": ["scripts/*.js", "dangerfile.js", "config/*.js"],
      "project": ["{config,scripts}/**/*.js"]
    },
    "packages/*": {
      "project": ["**/*.ts!"]
    },
    "packages/core": {
      "ignoreDependencies": ["graphql-config"]
    },
    "packages/utils": {
      "project": ["**/*.ts!"],
      "ignoreDependencies": ["prettier"]
    }
  },
  "ignoreDependencies": [
    "@docusaurus/logger",
    "commitizen",
    "danger",
    "husky",
    "jest-environment-node"
  ],
  "jest": {
    "config": ["config/jest.config.js"],
    "entry": ["**/tests/**/*.ts"]
  },
  "eslint": {
    "config": ["config/.eslintrc.js"]
  }
}
