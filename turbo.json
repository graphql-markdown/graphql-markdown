{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "bun.lock",
    "tsconfig.base.json",
    "package.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**/*.ts", "tsconfig*.json", "package.json"]
    },
    "clean": {
      "cache": false
    },
    "stryker": {
      "dependsOn": ["^build"],
      "outputs": ["reports/**"],
      "cache": false
    },
    "docs": {
      "dependsOn": ["^build"],
      "outputs": ["docs/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "package.json"]
    },
    "lint:fix": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "prettier": {},
    "prettier:fix": {
      "cache": false
    },
    "ts:check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tests/**/*.ts", "tsconfig*.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.ts",
        "tests/unit/**/*.ts",
        "tests/__mocks__/**/*.ts",
        "tsconfig*.json",
        "jest.config.mjs",
        "package.json"
      ]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.ts",
        "tests/integration/**/*.ts",
        "tests/__mocks__/**/*.ts",
        "tsconfig*.json",
        "jest.config.mjs",
        "package.json"
      ]
    },
    "test:ci": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "tests/__mocks__/**/*.ts",
        "tsconfig*.json",
        "jest.config.mjs",
        "package.json"
      ]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "//#docs:api:root": {
      "dependsOn": ["^build"],
      "outputs": ["api/**", "!api/@@graphql-markdown/**"]
    }
  }
}
